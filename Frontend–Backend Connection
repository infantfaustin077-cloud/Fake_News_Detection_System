Flask Backend (app.py):

@app.route('/predict', methods=['POST'])

def predict():

    data = request.get_json()

    news = data['news']

    vector = vectorizer.transform([news])

    prediction = model.predict(vector)

    if prediction[0] == 1:

        result = "Real News"

    else:

        result = "Fake News"

    return jsonify({
        "result": result
    })

