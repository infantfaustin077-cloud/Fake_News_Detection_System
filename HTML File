<!DOCTYPE html>

<html>

<head>

<title>Fake News Detection</title>

<link rel="stylesheet" href="/static/style.css">

</head>

<body>

<div class="container">

<h1>Fake News Detection System</h1>

<form action="/predict" method="POST">

<textarea name="news"
rows="10"
cols="60"
placeholder="Enter news article">
</textarea>

<br><br>

<button type="submit">
Check News
</button>

</form>

{% if prediction %}

<h2>{{ prediction }}</h2>

{% endif %}

</div>

</body>

</html>